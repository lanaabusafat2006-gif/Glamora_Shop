<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Webproject</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Webproject.styles.css" asp-append-version="true" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nosifer&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        .footer-container {
            width: 90%;
            margin: auto;
        }

        .footer-grid {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            gap: 30px;
        }

        .footer-column {
            flex: 1;
            min-width: 180px;
        }

        .footer-copy {
            color: rgba(255,255,255,0.6);
            font-size: 17px;
            margin-top: 10px;
        }

        
        html, body {
            height: 100%;
        }

        body {
            display: flex;
            flex-direction: column;
            background-color: #fffafb;
        }

        .content-wrapper {
            flex: 1 0 auto;
        }

        .footer-wrapper {
            flex-shrink: 0;
        }

       
        .glamora-footer {
            background-color: #d67d93; 
            color: #ffffff;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding-top: 40px;
            padding-bottom: 20px;
            margin-top: 50px;
        }

        .glamora-footer a {
            color: rgba(255, 255, 255, 0.60);
            text-decoration: none;
            font-size: 11px;
            display: block;
            margin-bottom: 6px;
            transition: color 0.2s ease;
        }

        .glamora-footer a:hover {
            color: #ffffff;
        }

        .glamora-footer h5 {
            color: #ffffff;
            font-size: 15px;
            font-weight: 600;
            margin-bottom: 15px;
            letter-spacing: 0.5px;
        }

        .footer-logo {
            font-family: 'Nosifer', sans-serif;
            font-size: 25.5px; 
            margin-bottom: 15px;
            letter-spacing: 1px;
            color: #ffffff;
        }

        .social-icons a {
            display: inline-block;
            font-size: 19px;
            margin-right: 12px;
            color: rgba(255, 255, 255, 0.8);
            text-decoration: none;
        }

            .social-icons a:hover {
                color: #ffffff;
            }

        .nav-link:hover {
            color: #b83b5e !important;
        }
    </style>
</head>
<body>

    <div class="content-wrapper">
        <header>
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
                <div class="container-fluid">
                    <a class="navbar-brand fw-bold" style="color: #b83b5e; font-family:'Nosifer', sans-serif; " asp-area="" asp-controller="Home" asp-action="Index">Glamora</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                            @if (Context.Session.GetInt32("UserId") != null)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Products" asp-action="Index">Products</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Orders" asp-action="MyOrders">My Orders</a>
                                </li>

                                <li class="nav-item" style="margin-left:auto">
                                    <a class="nav-link text-dark"  asp-controller="Account" asp-action="Profile">Profile</a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item" style="margin-left:auto">
                                    <a class="nav-link text-dark" asp-controller="Account" asp-action="SignIn">Login</a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <div class="container">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    </div>

   
    <div class="footer-wrapper">
        <footer class="glamora-footer">

            <div class="footer-container">

                <div class="footer-grid">

                    <div class="footer-column">
                        <div class="footer-logo">GLAMORA</div>

                        <p class="footer-copy">
                            © 2026 Glamora Shop.<br>
                            All Rights Reserved.
                        </p>
                    </div>

                    <div class="footer-column">
                        <h5>ABOUT US</h5>

                        <a href="#">ABOUT GLAMORA</a>
                        <a href="#">GLAMORA VIPS CLUB</a>
                        <a href="#">AMBASSADOR PROGRAM</a>
                        <a href="#">CAREERS</a>
                        <a href="#">OUR BLOG</a>
                    </div>

                    <div class="footer-column">
                        <h5>CONTACT US</h5>

                        <a href="#">CUSTOMER SERVICE</a>
                        <a href="#">SHIPPING & DELIVERY</a>
                        <a href="#">TRACK MY ORDER</a>
                        <a href="#">RETURNS & REFUNDS</a>
                        <a href="#">STORE LOCATOR</a>
                    </div>

                    <div class="footer-column">
                        <h5>TERMS & POLICIES</h5>

                        <a href="#">TERMS & CONDITIONS OF SALE</a>
                        <a href="#">PRIVACY POLICY</a>
                        <a href="#">COOKIE POLICY</a>
                        <a href="#">TERMS OF USE</a>
                        <a href="#">ACCESSIBILITY</a>
                    </div>

                    <div class="footer-column">
                        <h5 style="font-weight:bold; color:white; margin-bottom:16px; font-size:17.5px;">
                            LET'S <br> CONNECT
                        </h5>

                        <div class="social-icons">
                            <a href="#"><i class="fab fa-instagram"></i></a>
                            <a href="#"><i class="fab fa-whatsapp"></i></a>
                            <a href="#"><i class="fas fa-globe"></i></a>
                        </div>
                    </div>

                </div>

            </div>

        </footer>
        ```

    </div>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>