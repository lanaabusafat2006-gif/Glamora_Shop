@model Webproject.Models.User

@{
    ViewData["Title"] = "Sign Up";
}

<div class="main-page">
    <div class="box">
        <h3 class="title">Sign Up</h3>

        <form asp-action="SignUp" method="post">
            <div class="field">
                <label class="label">Email</label>
                <input type="email" asp-for="Email" class="input" required placeholder="example@mail.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="field">
                <label class="label">Password</label>
                <input type="password" asp-for="Password" class="input" required placeholder="********" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="field">
                <label class="label">Full Name</label>
                <input type="text" asp-for="FullName" class="input" required placeholder="Enter your full name" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <button type="submit" class="btn">Register</button>
        </form>

        <div class="footer">
            Already have an account? <a asp-action="SignIn">Login</a>
        </div>
    </div>
</div>